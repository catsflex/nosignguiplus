{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "version": "${mod_version}",
  "authors": [
    "${mod_author}"
  ],
  "contact": {
    "homepage": "${mod_homepage_url}",
    "sources": "${mod_sources_url}",
    "issues": "${mod_issues_url}"
  },
  "license": "${mod_license}",
  "icon": "assets/${mod_id}/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "me.catsflex.nosignguiplus.NoSignGUIPlusClient"
    ],
    "modmenu": [
      "me.catsflex.${mod_id}.config.ModMenuIntegration"
    ]
  },
  "mixins": [
    "${mod_id}.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "minecraft": ">=${minecraft_version}"
  },
  "suggests": {
    "modmenu": ">=${modmenu_version}",
    "yet_another_config_lib": ">=${yacl_version}"
  }
}
